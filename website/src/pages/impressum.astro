---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Impressum — WhisPaste">
  <div class="min-h-screen flex flex-col">
    <Nav variant="subpage" />

    <!-- Content -->
    <main class="flex-1 pt-24 pb-16 px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl font-bold text-white mb-8" id="pageTitle">Legal Notice (Impressum)</h1>

        <div class="prose prose-invert max-w-none space-y-6 text-gray-300 leading-relaxed">
          <!-- DE content (default visible) -->
          <div id="content-de" class="hidden space-y-6">
            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Angaben gemäß § 5 DDG</h2>
              <p>
                <strong class="text-white">Silvio Lindstedt und Maik Gräfendorf, GbR</strong><br>
                Pappelweg 27<br>
                39576 Stendal<br>
                Deutschland
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Kontakt</h2>
              <p>
                E-Mail: silvio-linstedt@outlook.com
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
              <p>
                Silvio Lindstedt<br>
                Anschrift wie oben
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Haftungsausschluss</h2>
              <h3 class="text-lg font-medium text-white mb-2">Haftung für Inhalte</h3>
              <p>
                Die Inhalte dieser Seite wurden mit größter Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte kann jedoch keine Gewähr übernommen werden. Als Diensteanbieter bin ich gemäß § 7 Abs. 1 DDG für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich. Nach §§ 8 bis 10 DDG bin ich jedoch nicht verpflichtet, übermittelte oder gespeicherte fremde Informationen zu überwachen.
              </p>
              <h3 class="text-lg font-medium text-white mb-2 mt-4">Haftung für Links</h3>
              <p>
                Diese Seite enthält Links zu externen Websites Dritter, auf deren Inhalte ich keinen Einfluss habe. Für die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter oder Betreiber verantwortlich. Bei Bekanntwerden von Rechtsverletzungen werde ich derartige Links umgehend entfernen.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Urheberrecht</h2>
              <p>
                WhisPaste ist Open-Source-Software, lizenziert unter der <a href="https://github.com/whispaste/whispaste/blob/main/LICENSE" target="_blank" rel="noopener" class="text-brand-cyan hover:underline">MIT-Lizenz</a>. Der Quellcode ist öffentlich auf <a href="https://github.com/whispaste/whispaste" target="_blank" rel="noopener" class="text-brand-cyan hover:underline">GitHub</a> verfügbar.
              </p>
            </section>
          </div>

          <!-- EN content -->
          <div id="content-en" class="space-y-6">
            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Information according to § 5 DDG (German Digital Services Act)</h2>
              <p>
                <strong class="text-white">Silvio Lindstedt und Maik Gräfendorf, GbR</strong><br>
                Pappelweg 27<br>
                39576 Stendal<br>
                Germany
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Contact</h2>
              <p>
                Email: silvio-linstedt@outlook.com
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Responsible for content according to § 18 (2) MStV</h2>
              <p>
                Silvio Lindstedt<br>
                Address as above
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Disclaimer</h2>
              <h3 class="text-lg font-medium text-white mb-2">Liability for content</h3>
              <p>
                The contents of this website have been created with the utmost care. However, no guarantee can be given for the accuracy, completeness, or timeliness of the content. As a service provider, I am responsible for my own content on these pages in accordance with general laws pursuant to § 7 (1) DDG. However, pursuant to §§ 8–10 DDG, I am not obligated to monitor transmitted or stored third-party information.
              </p>
              <h3 class="text-lg font-medium text-white mb-2 mt-4">Liability for links</h3>
              <p>
                This website contains links to external third-party websites over whose content I have no influence. The respective provider or operator is always responsible for the content of the linked pages. If I become aware of any legal violations, I will remove such links immediately.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-semibold text-white mb-3">Copyright</h2>
              <p>
                WhisPaste is open-source software, licensed under the <a href="https://github.com/whispaste/whispaste/blob/main/LICENSE" target="_blank" rel="noopener" class="text-brand-cyan hover:underline">MIT License</a>. The source code is publicly available on <a href="https://github.com/whispaste/whispaste" target="_blank" rel="noopener" class="text-brand-cyan hover:underline">GitHub</a>.
              </p>
            </section>
          </div>
        </div>
      </div>
    </main>

    <Footer variant="subpage" />
  </div>

  <script>
    import { applyLang, currentLang } from '../scripts/i18n';
    import { updateThemeIcon } from '../scripts/theme';

    function applyPageLang() {
      const lang = (window as any).currentLang || localStorage.getItem('whispaste-lang') || 'en';
      const title = document.getElementById('pageTitle');
      if (title) title.textContent = lang === 'de' ? 'Impressum' : 'Legal Notice (Impressum)';
      document.getElementById('content-de')?.classList.toggle('hidden', lang !== 'de');
      document.getElementById('content-en')?.classList.toggle('hidden', lang !== 'en');
    }

    // Wrap toggleLang to also update page-specific content
    const origToggle = (window as any).toggleLang;
    (window as any).toggleLang = function() {
      origToggle();
      applyPageLang();
    };

    applyLang();
    applyPageLang();
    updateThemeIcon();
  </script>
</Layout>
