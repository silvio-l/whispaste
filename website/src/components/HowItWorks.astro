<!-- How It Works Section -->
<section id="how-it-works" class="py-24 sm:py-32 relative scroll-mt-20">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_rgba(14,116,144,0.08)_0%,_transparent_60%)]"></div>
  <div class="relative max-w-5xl mx-auto px-6">
    <div class="text-center mb-16 scroll-reveal">
      <p class="text-brand-cyan text-sm font-semibold tracking-wider uppercase mb-3" data-i18n="howitworks.label">Workflow</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white" data-i18n="howitworks.title">How it works</h2>
      <p class="mt-4 text-gray-400 text-lg" data-i18n="howitworks.desc">Three steps. Zero friction.</p>
    </div>
    <div class="relative">
      <!-- Connecting line (desktop only) -->
      <div class="hidden lg:block absolute top-8 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-brand-cyan/0 via-brand-cyan/30 to-brand-cyan/0"></div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        {[
          { step: "1", icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m9 8 3 3-3 3"/><path d="M14 16h4"/></svg>`, title: "Press Hotkey", desc: "Hit your hotkey from any app" },
          { step: "2", icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`, title: "Speak & Transcribe", desc: "Whisper converts your speech to text" },
          { step: "3", icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>`, title: "Auto-Paste", desc: "Text appears at your cursor" },
        ].map(({ step, icon, title, desc }) => (
          <div class="text-center scroll-reveal">
            <div class="relative inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-card/80 border border-brand-border/60 mb-4 text-brand-cyan shadow-lg shadow-brand-cyan/[0.05]" set:html={icon}>
            </div>
            <div class="text-xs font-mono text-brand-cyan tracking-wider mb-1.5">Step {step}</div>
            <h3 class="text-white font-semibold mb-1">{title}</h3>
            <p class="text-gray-400 text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
